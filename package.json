{
  "name": "sing-box-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "generate": "buf generate && node scripts/gen-terminal-themes.mjs",
