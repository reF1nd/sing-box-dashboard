    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "luby-transform": "0.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "uqr": "^0.1.3"
  },
  "devDependencies": {
